{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDbSettings": {
    "ConnectionString": "<set-in-appsettings.Local.json-or-environment>",
    "DatabaseName": "parking_main_db"
  },
  "PaymentServiceSettings": {
    "BaseUrl": "http://localhost:5003"
  },
  "JwtSettings": {
    "Secret": "<set-in-appsettings.Local.json-or-environment>",
    "Issuer": "ParkingSystemAPI",
    "Audience": "ParkingSystemClient",
    "ExpirationInMinutes": 60,
    "RefreshExpirationInDays": 7
  }
}
