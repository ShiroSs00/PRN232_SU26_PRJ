# ==============================================================================
# PARKING MANAGER - MICROSERVICES CONFIGURATION
# ==============================================================================

# MongoDB Configuration
# Option 1: Local MongoDB (docker-compose)
MONGODB_CONNECTION_STRING=mongodb://admin:P@ssw0rd123@localhost:27017

# Option 2: MongoDB Atlas (Cloud) - Recommended for production
# MONGODB_CONNECTION_STRING=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# MongoDB Database Names
AUTH_DATABASE_NAME=parking_auth_db
PARKING_DATABASE_NAME=parking_main_db
PAYMENT_DATABASE_NAME=parking_payment_db
REPORT_DATABASE_NAME=parking_report_db

# ==============================================================================
# SERVICE PORTS
# ==============================================================================
GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
PARKING_SERVICE_PORT=5002
PAYMENT_SERVICE_PORT=5003
REPORT_SERVICE_PORT=5004

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================
JWT_SECRET=your-super-secret-key-change-this-in-production-min-32-chars-long
JWT_ISSUER=ParkingSystemAPI
JWT_AUDIENCE=ParkingSystemClient
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4200

# ==============================================================================
# INTER-SERVICE COMMUNICATION
# ==============================================================================
AUTH_SERVICE_URL=http://localhost:5001
PARKING_SERVICE_URL=http://localhost:5002
PAYMENT_SERVICE_URL=http://localhost:5003
REPORT_SERVICE_URL=http://localhost:5004

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=Information
LOG_TO_FILE=true
LOG_PATH=logs

# ==============================================================================
# ASPNET CORE CONFIGURATION
# ==============================================================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ==============================================================================
# OPTIONAL: MESSAGE QUEUE (RabbitMQ) - For event-driven communication
# ==============================================================================
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD=guest
# RABBITMQ_VIRTUAL_HOST=/

# ==============================================================================
# MONGODB ATLAS EXAMPLE CONNECTION STRINGS
# ==============================================================================
# Free Tier (M0): mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/
# Shared Tier (M2/M5): mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/
# Add database name and options: ?retryWrites=true&w=majority&appName=ParkingSystem
