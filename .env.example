# API Gateway
GATEWAY_PORT=5000

# Auth Service
AUTH_SERVICE_PORT=5001
AUTH_DB_CONNECTION=mongodb://localhost:27017/parking_auth_db

# Parking Service
PARKING_SERVICE_PORT=5002
PARKING_DB_CONNECTION=mongodb://localhost:27017/parking_main_db

# Payment Service
PAYMENT_SERVICE_PORT=5003
PAYMENT_DB_CONNECTION=mongodb://localhost:27017/parking_payment_db

# Report Service
REPORT_SERVICE_PORT=5004
REPORT_DB_CONNECTION=mongodb://localhost:27017/parking_report_db

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ISSUER=ParkingSystemAPI
JWT_AUDIENCE=ParkingSystemClient
JWT_EXPIRY_MINUTES=60

# MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_PORT=27017

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# RabbitMQ (Optional - for event-driven communication)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Redis (Optional - for caching)
REDIS_CONNECTION=localhost:6379

# Logging
LOG_LEVEL=Information
